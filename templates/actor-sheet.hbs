                            </td>
                            <td class="center">
                                {{#if system.combat.arme3.nom}}
                                  <a class="axv-weapon-attack" data-weapon-key="arme3" title="{{#if system.combat.arme3.equipe}}Lancer une attaque{{else}}Coche Équipé pour attaquer{{/if}}" {{#unless system.combat.arme3.equipe}}style="opacity:.35;pointer-events:auto;"{{/unless}}>
                                    <i class="fa-solid fa-swords"></i>
                                  </a>
                                {{/if}}
                            </td>
                        </tr>

                        <tr>
                            <td><input type="text" name="system.combat.arme4.nom" value="{{system.combat.arme4.nom}}"/></td>
                            <td><input type="text" name="system.combat.arme4.degats" value="{{system.combat.arme4.degats}}" class="center"/></td>
                            <td><input type="text" name="system.combat.arme4.portee" value="{{system.combat.arme4.portee}}" class="center"/></td>
                            <td><input type="text" name="system.combat.arme4.munitions" value="{{system.combat.arme4.munitions}}" class="center"/></td>
                            <td>
                                <select name="system.combat.arme4.skillKey" data-weapon-path="system.combat.arme4.skillKey" class="axv-weapon-skill" data-current="{{system.combat.arme4.skillKey}}">
                                    <option value="">—</option>
                                    <option value="combat1">{{#if system.competences.combat1.label}}{{system.competences.combat1.label}}{{else}}Combat 1{{/if}}</option>
                                    <option value="combat2">{{#if system.competences.combat2.label}}{{system.competences.combat2.label}}{{else}}Combat 2{{/if}}</option>
                                    <option value="combat3">{{#if system.competences.combat3.label}}{{system.competences.combat3.label}}{{else}}Combat 3{{/if}}</option>
                                </select>
                            </td>
                            <td class="center">
                                <input type="checkbox" class="axv-weapon-equipped" data-weapon-key="arme4" {{checked system.combat.arme4.equipe}} title="Arme équipée"/>
                            </td>
                            <td class="center">
                                {{#if system.combat.arme4.nom}}
                                  <a class="axv-weapon-attack" data-weapon-key="arme4" title="{{#if system.combat.arme4.equipe}}Lancer une attaque{{else}}Coche Équipé pour attaquer{{/if}}" {{#unless system.combat.arme4.equipe}}style="opacity:.35;pointer-events:auto;"{{/unless}}>
                                    <i class="fa-solid fa-swords"></i>
                                  </a>
                                {{/if}}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab" data-tab="description">
            <div class="axv-description-grid">
                <section class="axv-sheet-panel axv-sheet-panel--full">
                    <h2 class="comp-title">Équipement</h2>
                    <div class="textarea-box textarea-box--medium">
                        {{#if actor.isOwner}}
                        <textarea name="system.description.equipement">{{system.description.equipement}}</textarea>
                        {{else}}
                        <div class="axv-text-display">{{{enrichedDescription.equipement}}}</div>
                        {{/if}}
                    </div>
                </section>

                <section class="axv-sheet-panel axv-sheet-panel--full axv-notes-panel">
                    <h2 class="comp-title">Notes</h2>
                    <div class="textarea-box textarea-box--medium">
                        {{#if actor.isOwner}}
                        <textarea name="system.description.notes">{{system.description.notes}}</textarea>
                        {{else}}
                        <div class="axv-text-display">{{{enrichedDescription.notes}}}</div>
                        {{/if}}
                    </div>
                </section>
            </div>
        </div>

        
        <div class="tab" data-tab="atouts">
            <div class="axv-atouts-layout">
                <section class="axv-atouts-section">
                    <div class="axv-atouts-hero">
                        <div>
                            <h2 class="comp-title">Atouts du personnage</h2>
                        </div>
                    </div>

                    {{#if characterAtoutCards.length}}
                    <div class="axv-character-atout-grid">
                        {{#each characterAtoutCards}}
                        <article class="axv-character-atout-card">
                            <div class="axv-character-atout-title">{{this.name}}</div>
                            <div class="axv-character-atout-effect">
                                <strong>Effet courant</strong>
                                <p>{{this.currentEffect}}</p>
                            </div>
                            <div class="axv-character-atout-effect">
                                <strong>Effet héroïque</strong>
                                <p>{{this.heroicEffect}}</p>
                            </div>
                        </article>
                        {{/each}}
                    </div>
                    {{else}}
                    <div class="axv-arcana-empty">Aucun</div>
                    {{/if}}
                </section>

                <section class="axv-atouts-section">
                    <div class="axv-atouts-hero">
                        <div>
                            <h2 class="comp-title">Atouts d’arcane majeur</h2>
                        </div>
                    </div>

                    <div class="axv-arcana-panel" data-arcana-dropzone="1">
                        {{#if arcaneAtouts.length}}
                        <div class="axv-arcana-list">
                            {{#each arcaneAtouts}}
                            <article class="axv-arcana-card {{#if this.active}}is-active{{/if}}">
                                <div class="axv-arcana-media">
                                    <img class="axv-arcana-image" src="{{this.img}}" alt="{{this.name}}"/>
                                </div>
                                <div class="axv-arcana-body">
                                    <div class="axv-arcana-head">
                                        <div>
                                            <div class="axv-arcana-name">{{this.name}}</div>
                                            <div class="axv-arcana-sataniste">{{this.sataniste}}</div>
                                        </div>
                                        <div class="axv-arcana-state">{{#if this.active}}ACTIF{{else}}LIÉ{{/if}}</div>
                                    </div>
                                    <div class="axv-arcana-effect">
                                        <strong>Effet courant</strong>
                                        <p>{{this.currentEffect}}</p>
                                    </div>
                                    <div class="axv-arcana-effect">
                                        <strong>Effet héroïque</strong>
                                        <p>{{this.heroicEffect}}</p>
                                    </div>
                                    {{#if ../canManageArcana}}
                                    <div class="axv-arcana-actions">
                                        {{#if this.active}}
                                        <button type="button" class="axv-arcana-btn axv-arcana-deactivate" data-item-id="{{this.id}}">Désactiver</button>
                                        {{else}}
                                        <button type="button" class="axv-arcana-btn axv-arcana-activate" data-item-id="{{this.id}}">Activer</button>
                                        {{/if}}
                                        <button type="button" class="axv-arcana-btn axv-arcana-heroic" data-item-id="{{this.id}}">Effet héroïque (-{{this.heroicCost}} Destin)</button>
                                        <button type="button" class="axv-arcana-btn axv-arcana-remove" data-item-id="{{this.id}}">Retirer</button>
                                    </div>
                                    {{/if}}
                                </div>
                            </article>
                            {{/each}}
                        </div>
                        {{else}}
                        <div class="axv-arcana-empty">Aucun</div>
                        {{/if}}
                    </div>
                </section>
            </div>
        </div>

        <div class="tab" data-tab="main">
            <div class="axv-sheet-panel axv-sheet-panel--full">
                <div class="axv-main-tab-head">
                    <div>
                        <h2 class="comp-title">Main</h2>
                        <p class="axv-atouts-help">Les cartes sont regroupées ici pour alléger le reste de la fiche.</p>
                    </div>
                </div>
                {{#if canViewHand}}
                <div class="hand-container hand-container--tab">
                    {{#each cards}}
                    <div class="hand-card hand-card--compact" title="{{this.name}}">
                        <img class="hand-card-image" src="{{this.img}}" alt="{{this.name}}" draggable="false"/>
                        <div class="hand-card-meta">
                            <div class="hand-card-label">{{this.name}}</div>
                        </div>
                    </div>
                    {{else}}
                    <div class="hand-empty">Aucune carte (Créez un nouvel acteur)</div>
                    {{/each}}
                </div>
                {{else}}
                <div class="hand-empty">Main masquée sur cette fiche.</div>
                {{/if}}
            </div>
        </div>
    </section>
</div>