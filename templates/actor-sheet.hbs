                                <select name="system.combat.arme4.skillKey" data-weapon-path="system.combat.arme4.skillKey" class="axv-weapon-skill" data-current="{{system.combat.arme4.skillKey}}">
                                    <option value="">—</option>
                                    <option value="combat1">{{#if system.competences.combat1.label}}{{system.competences.combat1.label}}{{else}}Combat 1{{/if}}</option>
                                    <option value="combat2">{{#if system.competences.combat2.label}}{{system.competences.combat2.label}}{{else}}Combat 2{{/if}}</option>
                                    <option value="combat3">{{#if system.competences.combat3.label}}{{system.competences.combat3.label}}{{else}}Combat 3{{/if}}</option>
                                </select>
                            </td>
                            <td class="center">
                                {{#if system.combat.arme4.nom}}
                                  <a class="axv-weapon-attack" data-weapon-key="arme4" title="Lancer une attaque">
                                    <i class="fa-solid fa-swords"></i>
                                  </a>
                                {{/if}}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="tab" data-tab="description">
            <h2 class="comp-title">Arcanes Majeurs</h2>
            <div class="textarea-box"><textarea name="system.description.arcanes" rows="4">{{system.description.arcanes}}</textarea></div>
            <h2 class="comp-title">Atouts</h2>
            <div class="textarea-box"><textarea name="system.description.atouts" rows="4">{{system.description.atouts}}</textarea></div>
            <h2 class="comp-title">Équipement</h2>
            <div class="textarea-box"><textarea name="system.description.equipement" rows="6">{{system.description.equipement}}</textarea></div>
            <h2 class="comp-title">Notes</h2>
            <div class="textarea-box"><textarea name="system.description.notes" rows="8">{{system.description.notes}}</textarea></div>
        </div>
    </section>

    <footer class="hand-hud">
        <div class="hand-header">MAIN</div>
        <div class="hand-container">
            {{#each cards}}
            <div class="hand-card" data-id="{{this.id}}">
                <div class="card-inner"><span class="card-value">{{this.value}}</span><span class="card-suit">{{this.suit}}</span></div>
            </div>
            {{else}}
            <div class="hand-empty">Aucune carte (Créez un nouvel acteur)</div>
            {{/each}}
        </div>
    </footer>
</div>
