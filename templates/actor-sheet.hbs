<div class="sheet-container">
    
    <header class="sheet-header-main">
        <div class="identity-block">
            <div class="portrait-block" style="display:flex;align-items:center;justify-content:center;width:96px;min-width:96px;">
                <img class="character-portrait" src="{{actor.img}}" data-edit="img" title="{{actor.name}}" style="width:88px;height:88px;object-fit:cover;border-radius:10px;cursor:pointer;" />
            </div>
            <div class="identity-fields" style="flex:1;min-width:0;">
                <div class="field-large"><input name="system.biographie.nom" type="text" value="{{system.biographie.nom}}" placeholder="Nom"/></div>
                <div class="field-sub"><input name="system.biographie.profession" type="text" value="{{system.biographie.profession}}" placeholder="Profession"/></div>
            </div>
        </div>
        <div class="logo-mini">ARCANE XV</div>
    </header>

    <section class="stats-bar">
        <div class="stat-box"><label>DESTIN</label><input name="system.stats.destin" type="number" value="{{system.stats.destin}}"/></div>
        <div class="stat-box"><label>VITALITÉ</label><input name="system.stats.vitalite" type="number" value="{{system.stats.vitalite}}"/></div>
        <div class="stat-box"><label>BLESSURES</label><input name="system.stats.blessures" type="number" value="{{system.stats.blessures}}"/></div>
        <div class="vl"></div>
        <div class="stat-box"><label>SOMME</label><input name="system.stats.sommeMax" type="number" value="{{system.stats.sommeMax}}"/></div>
        <div class="stat-box"><label>INITIATIVE</label><input name="system.stats.initiative" type="number" value="{{system.stats.initiative}}"/></div>
        <div class="stat-box"><label>PROTECTION</label><input name="system.stats.protection" type="number" value="{{system.stats.protection}}"/></div>
    </section>

    <nav class="sheet-tabs tabs">
        <a class="item" data-tab="competences">Compétences</a>
        <a class="item" data-tab="combat">Combat</a>
        <a class="item" data-tab="description">Description</a>
        <a class="item" data-tab="atouts">Atouts</a>
        <a class="item" data-tab="main">Main</a>
    </nav>

