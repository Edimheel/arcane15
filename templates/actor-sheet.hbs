        <div class="tab" data-tab="combat">
            <h2 class="comp-title">Combat</h2>
            <div class="combat-section">
                <table class="combat-table">
                    <thead>
                        <tr>
                            <th>ARMES</th>
                            <th>DÉGÂTS</th>
                            <th>PORTÉE</th>
                            <th>MUN.</th>
                            <th>COMP.</th>
                            <th class="center" style="width:70px;">ÉQUIPÉ</th>
                            <th class="center" style="width:40px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><input type="text" name="system.combat.arme1.nom" value="{{system.combat.arme1.nom}}"/></td>
                            <td><input type="text" name="system.combat.arme1.degats" value="{{system.combat.arme1.degats}}" class="center"/></td>
                            <td><input type="text" name="system.combat.arme1.portee" value="{{system.combat.arme1.portee}}" class="center"/></td>
                            <td><input type="text" name="system.combat.arme1.munitions" value="{{system.combat.arme1.munitions}}" class="center"/></td>
                            <td>
                                <select name="system.combat.arme1.skillKey" data-weapon-path="system.combat.arme1.skillKey" class="axv-weapon-skill" data-current="{{system.combat.arme1.skillKey}}">
                                    <option value="">—</option>
                                    <option value="combat1">{{#if system.competences.combat1.label}}{{system.competences.combat1.label}}{{else}}Combat 1{{/if}}</option>
                                    <option value="combat2">{{#if system.competences.combat2.label}}{{system.competences.combat2.label}}{{else}}Combat 2{{/if}}</option>
                                    <option value="combat3">{{#if system.competences.combat3.label}}{{system.competences.combat3.label}}{{else}}Combat 3{{/if}}</option>
                                </select>
                            </td>
                            <td class="center">
                                <input type="checkbox" class="axv-weapon-equipped" data-weapon-key="arme1" {{checked system.combat.arme1.equipe}} title="Arme équipée"/>
                            </td>
                            <td class="center">
                                {{#if system.combat.arme1.nom}}
                                  <a class="axv-weapon-attack" data-weapon-key="arme1" title="{{#if system.combat.arme1.equipe}}Lancer une attaque{{else}}Coche Équipé pour attaquer{{/if}}" {{#unless system.combat.arme1.equipe}}style="opacity:.35;pointer-events:auto;"{{/unless}}>
                                    <i class="fa-solid fa-swords"></i>
                                  </a>
                                {{/if}}
                            </td>
                        </tr>

